<view class="container">
  <view wx:if="{{loading}}" class="loading">
    加载中...
  </view>
  <view wx:else>
    <!-- 商户信息 -->
    <view class="merchant-card">
      <view class="merchant-info">
        <text class="merchant-name">{{merchantInfo.name}}</text>
        <text class="merchant-address">{{merchantInfo.address}}</text>
        <text class="merchant-phone">{{merchantInfo.phone}}</text>
        <text class="merchant-description">{{merchantInfo.description}}</text>
      </view>
    </view>

    <!-- 服务项目 -->
    <view class="section">
      <text class="section-title">服务项目</text>
      <view class="services-container">
        <view wx:for="{{services}}" wx:key="id" class="card service-card" bindtap="goToServiceDetail" data-id="{{item.id}}">
          <view class="service-header">
            <text class="service-name">{{item.name}}</text>
            <text class="service-price">¥{{item.price}}</text>
          </view>
          <text class="service-description">{{item.description}}</text>
          <view class="service-footer">
            <text class="service-duration">{{item.duration}}分钟</text>
            <button class="btn btn-primary service-btn">查看详情</button>
          </view>
        </view>
        <view wx:if="{{services.length === 0}}" class="card empty-services">
          <text class="empty-icon">🛍️</text>
          <text>暂无服务项目</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 登录弹窗 -->
  <login-modal visible="{{showLoginModal}}" bind:close="onCloseLoginModal"></login-modal>
</view>