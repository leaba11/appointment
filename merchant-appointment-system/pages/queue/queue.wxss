/* 排队页面样式 */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.queue-info {
  text-align: center;
  padding: 24rpx 30rpx;
}

.queue-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.queue-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #4F46E5;
  margin-bottom: 12rpx;
  display: block;
}

.queue-subtitle {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.queue-status {
  font-size: 24rpx;
  color: #10B981;
  text-align: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #f0fff4;
  border-radius: 8rpx;
}

.estimated-time {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.queue-description {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.btn-primary {
  background-color: #4F46E5;
  color: white;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #4F46E5;
  border: 1rpx solid #4F46E5;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  position: relative;
  padding-left: 30rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 24rpx;
  background-color: #4F46E5;
  border-radius: 0 4rpx 4rpx 0;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.rule-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #4F46E5;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-content {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 排队列表样式 */
.queue-list {
  margin-top: 20rpx;
}

.queue-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.queue-item:last-child {
  border-bottom: none;
}

.queue-item-number {
  width: 60rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #4F46E5;
  margin-right: 20rpx;
}

.queue-item-customer {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.queue-item-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background-color: #E6F7FF;
  color: #1890FF;
}

.queue-item-status.called {
  background-color: #FFF1F0;
  color: #FF4D4F;
}

/* 服务选择弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 70vh;
  background-color: white;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
  max-height: 50vh;
}

.modal-footer {
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-footer .btn[disabled] {
  opacity: 0.5;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.service-item.selected {
  background-color: #EEF2FF;
  border-color: #4F46E5;
}

.service-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
}

.service-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #4F46E5;
}

/* 排队记录样式 */
.queue-records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.queue-record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border-left: 6rpx solid #4F46E5;
}

.queue-record-item.my-record {
  background-color: #EEF2FF;
  border-left-color: #10B981;
}

.record-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.record-service {
  font-size: 24rpx;
  color: #666;
}

.record-right {
  display: flex;
  align-items: center;
}

.record-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background-color: #E6F7FF;
  color: #1890FF;
}

.record-status.waiting {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.record-status.called {
  background-color: #FFF1F0;
  color: #FF4D4F;
}

.record-status.completed {
  background-color: #F6FFED;
  color: #52C41A;
}

.record-timer {
  font-size: 20rpx;
  color: #ff6b6b;
  margin-top: 8rpx;
  display: block;
}

.record-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.action-btn {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 16rpx;
  min-width: 60rpx;
  text-align: center;
}

.skip-btn {
  background-color: #ff6b6b;
  color: white;
}

.complete-btn {
  background-color: #4F46E5;
  color: white;
}

.empty-records {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

/* 排队队列样式 */
.queue-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.queue-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  border-left: 6rpx solid #4F46E5;
}

.queue-list-item.is-me {
  background-color: #EEF2FF;
  border-left-color: #10B981;
}

.queue-list-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.queue-list-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #4F46E5;
  min-width: 60rpx;
}

.queue-list-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.queue-list-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.queue-list-service {
  font-size: 22rpx;
  color: #999;
}

.queue-list-right {
  display: flex;
  align-items: center;
}

.queue-list-status {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: #E6F7FF;
  color: #1890FF;
}

.queue-list-status.waiting {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.queue-list-status.called {
  background-color: #FFF1F0;
  color: #FF4D4F;
}

.queue-list-status.completed {
  background-color: #F6FFED;
  color: #52C41A;
}

.queue-list-status.cancelled,
.queue-list-status.skipped {
  background-color: #f5f5f5;
  color: #999;
}

.queue-list-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}
