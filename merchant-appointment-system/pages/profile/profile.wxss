/* 个人中心页面样式 */
.profile-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 用户信息区域 */
.user-info-section {
  background-color: #4F46E5;
  padding: 40rpx;
  display: flex;
  align-items: center;
  color: white;
}

.user-avatar {
  margin-right: 30rpx;
  position: relative;
  z-index: 1;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  padding: 10rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.user-phone {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

/* 通用区块样式 */
.section {
  margin-top: 20rpx;
  background-color: white;
  border-radius: 16rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 24rpx;
  background-color: #4F46E5;
  border-radius: 0 4rpx 4rpx 0;
}

.title-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
}

/* 预约记录 */
.module-tabs {
  display: flex;
  padding: 20rpx;
  gap: 12rpx;
  background-color: #f9f9f9;
  border-bottom: 1rpx solid #e5e5e5;
}

.tab-btn {
  flex: 1;
  padding: 12rpx 0;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  background-color: #fff;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  transition: all 0.3s ease;
}

.tab-btn.active {
  background-color: #4F46E5;
  color: #fff;
  border-color: #4F46E5;
}

.appointment-subsection {
  margin: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e5e5e5;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.subsection-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.subsection-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.subsection-count {
  font-size: 20rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.appointment-list {
  padding: 20rpx;
}

.appointment-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.appointment-info {
  margin-bottom: 16rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.appointment-time {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.staff-name {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.appointment-status {
  margin-bottom: 16rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.status-tag.confirmed {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-tag.completed {
  background-color: #F6FFED;
  color: #52C41A;
}

.status-tag.cancelled {
  background-color: #FFF1F0;
  color: #FF4D4F;
}

.status-tag.pending {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.cancel-btn {
  background-color: #FF4D4F;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  min-width: 120rpx;
  text-align: center;
}

/* 服务记录 */
.service-list {
  padding: 20rpx;
}

.service-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.service-info {
  flex: 1;
}

.service-time {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.service-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF4D4F;
}

/* 联系商户 */
.contact-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.contact-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.contact-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  display: block;
}

.contact-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 其他 */
.other-list {
  display: flex;
  padding: 20rpx;
}

.other-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-right: 10rpx;
}

.other-item:last-child {
  margin-right: 0;
  margin-left: 10rpx;
}

.other-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  display: block;
}

.other-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 空状态 */
.empty-state {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  display: block;
  color: #ccc;
}

/* 拉框样式 */
.expand-box {
  padding: 20rpx;
  text-align: center;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  margin-top: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.expand-box:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.expand-text {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: bold;
}

/* 分页控件样式 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx 0;
}

.page-btn {
  background-color: #4F46E5;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  margin: 0 10rpx;
  min-width: 100rpx;
  text-align: center;
}

.page-btn.disabled {
  background-color: #ccc;
  color: #666;
}

.page-info {
  font-size: 20rpx;
  color: #666;
  margin: 0 10rpx;
}

/* 点击效果 */
.user-info-section,
.contact-item,
.other-item {
  cursor: pointer;
  transition: all 0.3s ease;
}

.user-info-section:active,
.contact-item:active,
.other-item:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 评分相关样式 */
.rating-display {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.rating-label {
  font-size: 22rpx;
  color: #666;
  margin-right: 8rpx;
}

.stars {
  display: flex;
}

.star {
  font-size: 28rpx;
  color: #ccc;
  margin-right: 4rpx;
}

.star.filled {
  color: #FFD700;
}

.rate-btn {
  background-color: #4F46E5;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.rate-btn.rated {
  background-color: #52C41A !important;
  color: white !important;
  opacity: 1 !important;
  border: none !important;
  background: #52C41A !important;
  border-color: #52C41A !important;
  box-shadow: none !important;
}

.rate-btn.rated-view {
  background-color: #52C41A;
  color: white;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  margin-top: 8rpx;
  text-align: center;
  line-height: 1.5;
}

/* 评分弹窗 */
.rating-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.rating-modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.rating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #4F46E5;
}

.rating-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.rating-close {
  font-size: 48rpx;
  color: white;
  line-height: 1;
  opacity: 0.8;
}

.rating-body {
  padding: 30rpx;
}

.rating-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.rating-staff-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.rating-service-name {
  font-size: 26rpx;
  color: #666;
}

.rating-section {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rating-section .rating-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.star-rating {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

.star-rating .star {
  font-size: 48rpx;
  margin-left: 8rpx;
  transition: color 0.2s ease;
}

.star-rating.disabled .star {
  pointer-events: none;
}

.total-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #4F46E5;
  margin-left: 16rpx;
}

.rating-comment {
  margin-top: 20rpx;
}

.comment-input {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.rating-footer {
  padding: 20rpx 30rpx 30rpx;
}

.submit-btn {
  width: 100%;
  background-color: #4F46E5;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 电话咨询弹窗 */
.phone-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.phone-modal-content {
  width: 100%;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.phone-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.phone-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.phone-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.phone-modal-body {
  text-align: center;
}

.phone-number {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.phone-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.phone-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #4F46E5;
}

.phone-tip {
  font-size: 26rpx;
  color: #999;
}

/* 电话操作弹窗 */
.phone-options-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1001;
}

.phone-options-content {
  width: 100%;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.phone-options-header {
  text-align: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.phone-options-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.phone-options-body {
  display: flex;
  flex-direction: column;
}

.phone-option-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background-color: #f9f9f9;
}

.phone-option-item.cancel {
  background-color: #f0f0f0;
}

.option-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.option-text {
  font-size: 30rpx;
  color: #333;
}

/* 地址弹窗 */
.address-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.address-modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: white;
  border-radius: 24rpx;
  overflow: hidden;
}

.address-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #4F46E5;
}

.address-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.address-modal-close {
  font-size: 48rpx;
  color: white;
  line-height: 1;
  opacity: 0.8;
}

.address-modal-body {
  padding: 30rpx;
}

.address-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.address-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 20rpx;
}

.address-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.address-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.address-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.address-phone {
  display: flex;
  align-items: center;
  justify-content: center;
}

.address-phone .phone-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.address-phone .phone-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.address-actions {
  display: flex;
  gap: 16rpx;
}

.address-action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333;
}
