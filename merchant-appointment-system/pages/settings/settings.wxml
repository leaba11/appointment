<view class="container">
  <view class="header">
    <text class="title">设置</text>
    <text class="back" bindtap="goBack">返回</text>
  </view>

  <view class="card">
    <text class="section-title">通用设置</text>
    
    <view class="setting-item">
      <text class="setting-label">通知提醒</text>
      <switch checked="{{notifications}}" bindchange="toggleNotifications" />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">位置服务</text>
      <switch checked="{{location}}" bindchange="toggleLocation" />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">自动登录</text>
      <switch checked="{{autoLogin}}" bindchange="toggleAutoLogin" />
    </view>
  </view>

  <view class="card">
    <text class="section-title">存储与缓存</text>
    <view class="setting-item" bindtap="clearCache">
      <text class="setting-label">清除缓存</text>
      <text class="setting-arrow">></text>
    </view>
  </view>

  <view class="card">
    <text class="section-title">账户管理</text>
    <view class="setting-item" bindtap="logout">
      <text class="setting-label" style="color: #ff3b30;">退出登录</text>
      <text class="setting-arrow">></text>
    </view>
  </view>
</view>