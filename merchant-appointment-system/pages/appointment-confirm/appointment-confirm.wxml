<view class="container">
  <!-- 预约信息 -->
  <view class="card">
    <text class="section-title">预约信息</text>
    <view class="info-item">
      <text class="info-label">服务项目：</text>
      <text class="info-value">{{service.name}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">服务员工：</text>
      <text class="info-value">{{staff.name}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">预约日期：</text>
      <text class="info-value">{{formatDate(date)}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">预约时间：</text>
      <text class="info-value">{{time}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">服务价格：</text>
      <text class="info-value price">¥{{service.price}}</text>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="card">
    <text class="section-title">个人信息</text>
    <view class="info-item">
      <text class="info-label">姓名：</text>
      <text class="info-value">{{name || '未设置'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">电话：</text>
      <text class="info-value">{{phone || '未设置'}}</text>
    </view>
    <textarea class="textarea" placeholder="备注信息（选填）" bindinput="inputRemark"></textarea>
  </view>

  <!-- 提交按钮 -->
  <button class="btn btn-primary" bindtap="submitAppointment">提交预约</button>
</view>