/* 全局样式 - Light 模式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f9fafb;
  color: #111827;
  min-height: 100vh;
  line-height: 1.5;
}

/* 容器 */
.container {
  padding: 16px;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  padding: 24px;
  margin-bottom: 20px;
  transition: all 0.2s ease;
  border: 1px solid #e5e7eb;
}

.card:hover {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
}

/* 按钮 */
.btn {
  display: block;
  width: 100%;
  height: 60px;
  line-height: 60px;
  text-align: center;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 600;
  margin-top: 20px;
  transition: all 0.2s ease;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  border: 1px solid transparent;
}

.btn-primary {
  background-color: #3b82f6;
  color: #ffffff;
}

.btn-primary:hover {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
}

.btn-secondary {
  background-color: #e5e7eb;
  color: #111827;
  border: 1px solid #e5e7eb;
}

.btn-secondary:hover {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
}

.btn-sm {
  height: 40px;
  line-height: 40px;
  font-size: 14px;
  padding: 0 16px;
  width: auto;
}

/* 标题 */
.section-title {
  font-size: 24px;
  font-weight: 700;
  margin: 24px 0 16px;
  color: #111827;
  position: relative;
  padding-left: 16px;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 24px;
  background-color: #3b82f6;
  border-radius: 2px;
}

.section-subtitle {
  font-size: 20px;
  font-weight: 600;
  margin: 20px 0 12px;
  color: #6b7280;
  position: relative;
  padding-left: 12px;
}

.section-subtitle::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 16px;
  background-color: #3b82f6;
  border-radius: 2px;
}

/* 服务卡片 */
.service-card {
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  padding: 24px;
  transition: all 0.2s ease;
  border: 1px solid #e5e7eb;
  margin-bottom: 16px;
  cursor: pointer;
}

.service-card:hover {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16px;
}

.service-name {
  font-size: 20px;
  font-weight: 600;
  color: #111827;
  flex: 1;
  margin-right: 16px;
}

.service-description {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 24px;
  line-height: 1.5;
  flex: 1;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.service-price {
  font-size: 24px;
  font-weight: 700;
  color: #ef4444;
  white-space: nowrap;
}

.service-duration {
  font-size: 12px;
  color: #6b7280;
  background-color: #f3f4f6;
  padding: 4px 12px;
  border-radius: 9999px;
  display: inline-block;
  border: 1px solid #e5e7eb;
}

/* 输入框 */
.input {
  width: 100%;
  height: 60px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  padding: 0 20px;
  font-size: 16px;
  margin-bottom: 20px;
  transition: all 0.2s ease;
  background-color: #ffffff;
  color: #111827;
}

.input:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}

.input::placeholder {
  color: #6b7280;
  font-size: 16px;
}

.input-group {
  position: relative;
  margin-bottom: 20px;
}

.input-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8px;
  padding-left: 4px;
}

.input-error {
  border-color: #ef4444 !important;
  box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1) !important;
}

.error-message {
  font-size: 12px;
  color: #ef4444;
  margin-top: 4px;
  padding-left: 4px;
}

/* 员工卡片 */
.staff-item {
  display: flex;
  align-items: center;
  padding: 20px;
  border-radius: 8px;
  transition: all 0.2s ease;
  margin-bottom: 12px;
  background-color: #ffffff;
  border: 1px solid #e5e7eb;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  cursor: pointer;
}

.staff-item:hover {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
  border-color: #3b82f6;
}

.staff-item.active {
  border-color: #3b82f6;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  background-color: rgba(59, 130, 246, 0.05);
}

.staff-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background-color: #3b82f6;
  margin-right: 20px;
  border: 2px solid #e5e7eb;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 700;
  color: #ffffff;
}

.staff-info {
  flex: 1;
}

.staff-name {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #111827;
}

.staff-specialty {
  font-size: 16px;
  color: #6b7280;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.staff-rating {
  font-size: 16px;
  color: #f59e0b;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.staff-rating::before {
  content: '⭐';
  margin-right: 4px;
  font-size: 20px;
}

/* 时间槽 */
.time-slot {
  display: inline-block;
  padding: 12px 20px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  margin: 8px 4px;
  font-size: 16px;
  font-weight: 600;
  transition: all 0.2s ease;
  background-color: #ffffff;
  min-width: 96px;
  text-align: center;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  cursor: pointer;
}

.time-slot:hover {
  border-color: #3b82f6;
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.time-slot.active {
  background-color: #3b82f6;
  color: #ffffff;
  border-color: #3b82f6;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transform: translateY(-1px);
}

.time-slot.disabled {
  background-color: #f3f4f6;
  color: #6b7280;
  border-color: #e5e7eb;
  cursor: not-allowed;
  opacity: 0.7;
}

.time-slot.disabled:hover {
  transform: none;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  border-color: #e5e7eb;
}

/* 排队信息 */
.queue-info {
  text-align: center;
  padding: 48px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  margin: 24px 0;
  border: 1px solid #e5e7eb;
}

.queue-number {
  font-size: 72px;
  font-weight: 700;
  color: #3b82f6;
  margin: 24px 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  letter-spacing: -0.05em;
}

.queue-label {
  font-size: 20px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8px;
}

.estimated-time {
  font-size: 20px;
  color: #6b7280;
  margin-top: 16px;
  background-color: #f3f4f6;
  padding: 12px 24px;
  border-radius: 9999px;
  display: inline-block;
  border: 1px solid #e5e7eb;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.queue-status {
  font-size: 16px;
  color: #3b82f6;
  font-weight: 600;
  margin-top: 16px;
  padding: 8px 20px;
  border-radius: 9999px;
  background-color: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.2);
  display: inline-block;
}

.queue-actions {
  margin-top: 32px;
  display: flex;
  justify-content: center;
  gap: 16px;
}

.queue-btn {
  padding: 12px 24px;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 600;
  transition: all 0.2s ease;
  border: none;
  min-width: 128px;
}

.queue-btn-primary {
  background-color: #3b82f6;
  color: #ffffff;
}

.queue-btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.queue-btn-secondary {
  background-color: #e5e7eb;
  color: #111827;
  border: 1px solid #e5e7eb;
}

.queue-btn-secondary:hover {
  border-color: #3b82f6;
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

/* 记录 */
.record-item {
  padding: 20px;
  border-radius: 8px;
  transition: all 0.2s ease;
  margin-bottom: 12px;
  background-color: #ffffff;
  border: 1px solid #e5e7eb;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.record-item:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  border-color: #3b82f6;
}

.record-title {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #111827;
  padding-left: 16px;
}

.record-time,
.record-service,
.record-staff {
  font-size: 16px;
  color: #6b7280;
  margin-bottom: 12px;
  padding-left: 16px;
  display: flex;
  align-items: center;
}

.record-time::before {
  content: '🕒';
  margin-right: 8px;
  font-size: 20px;
}

.record-service::before {
  content: '💈';
  margin-right: 8px;
  font-size: 20px;
}

.record-staff::before {
  content: '👨‍💼';
  margin-right: 8px;
  font-size: 20px;
}

.record-status {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 9999px;
  font-size: 14px;
  font-weight: 600;
  margin-top: 8px;
  margin-left: 16px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: all 0.2s ease;
}

.status-pending {
  background-color: #fff7ed;
  color: #f59e0b;
  border: 1px solid #fed7aa;
}

.status-confirmed {
  background-color: #eff6ff;
  color: #3b82f6;
  border: 1px solid #bfdbfe;
}

.status-completed {
  background-color: #ecfdf5;
  color: #10b981;
  border: 1px solid #a7f3d0;
}

.status-cancelled {
  background-color: #fef2f2;
  color: #ef4444;
  border: 1px solid #fecaca;
}

/* 商户信息卡片 */
.merchant-card {
  background-color: #3b82f6;
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  color: #ffffff;
  transition: all 0.2s ease;
}

.merchant-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

.merchant-info {
  text-align: center;
}

.merchant-name {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 16px;
}

.merchant-address, .merchant-phone {
  font-size: 20px;
  margin-bottom: 12px;
  opacity: 0.9;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.merchant-address::before {
  content: '📍';
  font-size: 24px;
}

.merchant-phone::before {
  content: '📞';
  font-size: 24px;
}

.merchant-description {
  font-size: 16px;
  margin-top: 16px;
  line-height: 1.5;
  opacity: 0.8;
  max-width: 80%;
  margin-left: auto;
  margin-right: auto;
}

/* 服务项目容器 */
.services-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
  margin-top: 16px;
}

/* 空状态 */
.empty-services {
  text-align: center;
  padding: 64px 16px;
  color: #6b7280;
  grid-column: 1 / -1;
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  border: 1px solid #e5e7eb;
}

.empty-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 16px;
  opacity: 0.5;
  color: #3b82f6;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 64px 0;
  font-size: 20px;
  color: #6b7280;
}

.loading::before {
  content: '';
  width: 24px;
  height: 24px;
  border: 2px solid #e5e7eb;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 12px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 服务详情页 */
.service-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 16px;
  color: #111827;
}

.service-price {
  font-size: 24px;
  font-weight: 700;
  color: #ef4444;
  margin-bottom: 12px;
}

.service-duration {
  font-size: 16px;
  color: #6b7280;
  background-color: #f3f4f6;
  padding: 8px 12px;
  border-radius: 9999px;
  display: inline-block;
  margin-bottom: 16px;
  border: 1px solid #e5e7eb;
}

.service-description {
  font-size: 16px;
  color: #6b7280;
  line-height: 1.5;
  margin-top: 16px;
}

/* 员工选择 */
.staff-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  padding: 8px 0;
}

/* 日期选择 */
.date-list {
  display: flex;
  overflow-x: auto;
  padding: 12px 0;
  gap: 12px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.date-list::-webkit-scrollbar {
  display: none;
}

.date-item {
  flex: 0 0 auto;
  width: 88px;
  text-align: center;
  padding: 20px 12px;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
  background-color: #ffffff;
  transition: all 0.2s ease;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  cursor: pointer;
}

.date-item:hover {
  border-color: #3b82f6;
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.date-item.active {
  background-color: #3b82f6;
  color: #ffffff;
  border-color: #3b82f6;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.date-day {
  font-size: 24px;
  font-weight: 700;
  display: block;
  margin-bottom: 4px;
}

.date-week {
  font-size: 14px;
  display: block;
  margin-bottom: 4px;
}

.date-month {
  font-size: 12px;
  display: block;
  opacity: 0.8;
}

/* 时间选择 */
.time-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: 12px;
  padding: 12px 0;
}

/* 预约确认页 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #e5e7eb;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 16px;
  color: #6b7280;
  font-weight: 500;
}

.info-value {
  font-size: 16px;
  color: #111827;
  font-weight: 600;
}

.info-value.price {
  color: #ef4444;
  font-size: 20px;
}

.textarea {
  width: 100%;
  height: 96px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  padding: 16px;
  font-size: 16px;
  margin-top: 16px;
  background-color: #ffffff;
  color: #111827;
  transition: all 0.2s ease;
  resize: none;
}

.textarea:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
}

.textarea::placeholder {
  color: #6b7280;
  font-size: 14px;
}

/* 个人中心页 */
.user-info {
  display: flex;
  align-items: center;
  padding: 24px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.user-info:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.user-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background-color: #3b82f6;
  margin-right: 20px;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 700;
  color: #ffffff;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 20px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4px;
  display: block;
}

.user-phone {
  font-size: 16px;
  color: #6b7280;
  display: block;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.empty-record {
  text-align: center;
  padding: 32px 16px;
  color: #6b7280;
  font-size: 16px;
}

.function-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  padding: 24px;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
  border-radius: 8px;
  transition: all 0.2s ease;
  cursor: pointer;
  background-color: #ffffff;
  border: 1px solid #e5e7eb;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.function-item:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  border-color: #3b82f6;
}

.function-icon {
  font-size: 40px;
  margin-bottom: 12px;
  display: block;
  transition: all 0.2s ease;
  color: #3b82f6;
}

.function-item:hover .function-icon {
  transform: scale(1.1);
}

.function-text {
  font-size: 14px;
  color: #111827;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
}

.function-item:hover .function-text {
  color: #3b82f6;
  font-weight: 600;
}

/* 排队页 */
.queue-title {
  font-size: 20px;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 12px;
  display: block;
  text-align: center;
}

.queue-subtitle {
  font-size: 16px;
  color: #6b7280;
  margin-top: 12px;
  display: block;
  text-align: center;
}

.queue-description {
  font-size: 14px;
  color: #6b7280;
  margin: 12px 0 20px;
  text-align: center;
  line-height: 1.5;
  max-width: 90%;
  margin-left: auto;
  margin-right: auto;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12px;
  padding-left: 0;
}

.rule-number {
  font-size: 12px;
  font-weight: 600;
  color: #ffffff;
  background-color: #3b82f6;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.rule-content {
  flex: 1;
  font-size: 14px;
  color: #6b7280;
  line-height: 1.5;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 12px;
  }
  
  .card {
    padding: 16px;
    margin-bottom: 12px;
  }
  
  .btn {
    height: 52px;
    line-height: 52px;
    font-size: 16px;
  }
  
  .section-title {
    font-size: 20px;
  }
  
  .service-name {
    font-size: 16px;
  }
  
  .service-price {
    font-size: 20px;
  }
  
  .queue-number {
    font-size: 48px;
  }
  
  .merchant-name {
    font-size: 24px;
  }
  
  .function-list {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  
  .date-item {
    width: 72px;
    padding: 12px 4px;
  }
  
  .time-slot {
    padding: 12px 16px;
    min-width: 80px;
  }
}

